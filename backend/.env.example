# =============================================================
# JWT Configuration
# =============================================================
# Generate a 256-bit Base64 encoded secret using:
# python3 -c "import base64; import secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=your-256-bit-base64-encoded-secret-key-here-replace-with-actual-secret

# =============================================================
# Google OAuth2 Configuration
# =============================================================
# Create OAuth credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# =============================================================
# GitHub OAuth2 Configuration
# =============================================================
# Create OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# =============================================================
# Database Configuration (for production use)
# =============================================================
MONGODB_UR=

# =============================================================
# Application Configuration
# =============================================================
# API_BASE_URL=http://localhost:8080
# FRONTEND_URL=http://localhost:5173

CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=
